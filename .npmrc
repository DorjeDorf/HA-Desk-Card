# Supply-chain protection ---------------------------------------------------
# Only install package versions that have been published for at least 7 days.
# Freshly-published versions are the ones most likely to be malicious (a
# compromised release is usually detected and pulled within a few days), so a
# cooldown window blocks them from landing in an install. Applies to all
# dependencies, including transitive ones. Value is in DAYS.
#
# Native to npm >= 11 (see `engines` in package.json). On older npm this key is
# silently ignored, which is why engine-strict below refuses to install on a
# toolchain that would not enforce it.
min-release-age=7

# Refuse to install unless the toolchain satisfies package.json "engines"
# (i.e. npm >= 11), so the cooldown above is always active — never a silent
# no-op that gives a false sense of protection.
engine-strict=true

# If a trusted package ever needs to bypass the cooldown (e.g. a critical
# hotfix you have vetted), list it here by name or glob:
# min-release-age-exclude[]=@your-scope/*
# min-release-age-exclude[]=some-package
